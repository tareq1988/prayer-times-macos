<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Prayer Times</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ar</string>
		<string>tr</string>
		<string>bn</string>
	</array>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<!-- Menu bar agent: no Dock icon, no main window (spec §3, §12). -->
	<key>LSUIElement</key>
	<true/>
	<!-- Used later by the optional location auto-detect (spec §7.7, §12). -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Prayer Times uses your location once to detect your city and the appropriate calculation method. It never tracks you continuously.</string>
	<!-- Sparkle auto-update (spec §7.8). Replace SUPublicEDKey with the public
	     key from `generate_keys`, and point SUFeedURL at the hosted appcast. -->
	<key>SUFeedURL</key>
	<string>https://tareq1988.github.io/prayer-times-macos/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>dHWH9EVDHeL09SIRBitm5iNE5NAe5Otlzt4CVgMxXbs=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
