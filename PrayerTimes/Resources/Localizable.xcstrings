    "Automatic updates are enabled in a later build.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تفعيل التحديثات التلقائية في إصدار لاحق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বয়ংক্রিয় আপডেট পরবর্তী বিল্ডে চালু হবে।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otomatik güncellemeler sonraki bir sürümde etkinleşir."
          }
        }
      }
    },
