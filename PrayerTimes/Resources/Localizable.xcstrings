    "Auto-detect method from location": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتشاف الطريقة من الموقع تلقائياً"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অবস্থান থেকে পদ্ধতি স্বয়ংক্রিয় শনাক্ত করুন"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yöntemi konumdan otomatik algıla"
          }
        }
      }
    },
    "Auto-detect on — locating…": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحديد التلقائي مُفعّل — جارٍ تحديد الموقع…"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বয়ংক্রিয় শনাক্তকরণ চালু — অবস্থান খোঁজা হচ্ছে…"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otomatik algılama açık — konum bulunuyor…"
          }
        }
      }
    },
