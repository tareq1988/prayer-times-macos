    "Guard strictly the prayers, especially the middle prayer, and stand before Allah devoutly obedient.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حَافِظُوا عَلَى الصَّلَوَاتِ وَالصَّلَاةِ الْوُسْطَىٰ وَقُومُوا لِلَّهِ قَانِتِينَ."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "তোমরা নামাজসমূহের প্রতি, বিশেষত মধ্যবর্তী নামাজের প্রতি যত্নবান হও এবং আল্লাহর সামনে বিনীতভাবে দাঁড়াও।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namazlara ve orta namaza devam edin; Allah'ın huzurunda gönülden boyun eğerek durun."
          }
        }
      }
    },
