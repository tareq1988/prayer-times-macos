    "Detect my location": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحديد موقعي"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আমার অবস্থান শনাক্ত করুন"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konumumu bul"
          }
        }
      }
    },
    "Detect your location to compute prayer times for where you are.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتشف موقعك لحساب أوقات الصلاة في مكانك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি যেখানে আছেন সেখানকার নামাজের সময় গণনা করতে আপনার অবস্থান শনাক্ত করুন।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulunduğunuz yerin namaz vakitlerini hesaplamak için konumunuzu algılayın."
          }
        }
      }
