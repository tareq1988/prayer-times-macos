    "Automatic updates are enabled in a later build.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تفعيل التحديثات التلقائية في إصدار لاحق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বয়ংক্রিয় আপডেট পরবর্তী বিল্ডে চালু হবে।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otomatik güncellemeler sonraki bir sürümde etkinleşir."
          }
        }
      }
    },
    "Based on the calculated Umm al-Qura calendar. Adjust if your country's date differs (it depends on local moon-sighting).": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بناءً على تقويم أم القرى المحسوب. عدِّله إذا كان تاريخ بلدك مختلفًا (فهو يعتمد على رؤية الهلال محليًا)."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "গণনাকৃত উম্মুল কুরা ক্যালেন্ডারের উপর ভিত্তি করে। আপনার দেশের তারিখ ভিন্ন হলে সমন্বয় করুন (এটি স্থানীয় চাঁদ দেখার উপর নির্ভর করে)।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesaplanmış Ümmü'l-Kura takvimine dayanır. Ülkenizin tarihi farklıysa ayarlayın (yerel hilal gözlemine bağlıdır)."
          }
        }
      }
    },
    "Blur intensity": {
      "localizations": {
        "ar": {
          "stringUnit": {
