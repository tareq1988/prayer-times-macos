    "Your timezone (%@) doesn't match your detected location (%@). Prayer times may be wrong — switch the timezone to “Follow system” or the matching zone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "منطقتك الزمنية (%@) لا تطابق موقعك المُكتشَف (%@). قد تكون أوقات الصلاة خاطئة — غيّر المنطقة الزمنية إلى «اتباع النظام» أو المنطقة المطابقة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার টাইমজোন (%@) আপনার শনাক্ত করা অবস্থানের (%@) সাথে মেলে না। নামাজের সময় ভুল হতে পারে — টাইমজোন “সিস্টেম অনুসরণ করুন” বা মিলে যাওয়া জোনে পরিবর্তন করুন।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat diliminiz (%@) algılanan konumunuzla (%@) eşleşmiyor. Namaz vakitleri yanlış olabilir — saat dilimini “Sistemi izle” veya eşleşen dilime değiştirin."
          }
        }
      }
    },
    "Zone": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المنطقة"
