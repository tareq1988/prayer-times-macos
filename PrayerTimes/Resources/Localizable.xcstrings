    "The Adhan reminder fires this many minutes before the jamaat time set below.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ينطلق تذكير الأذان قبل وقت الجماعة المحدد أدناه بهذا العدد من الدقائق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নিচে নির্ধারিত জামাতের সময়ের এত মিনিট আগে আজানের রিমাইন্ডার বাজবে।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezan hatırlatıcısı, aşağıda ayarlanan cemaat vaktinden bu kadar dakika önce çalar."
          }
        }
      }
    },
    "Times as announced by your mosque. The Adhan chip is the jamaat time minus the offset above.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأوقات كما يعلنها مسجدك. ملصق الأذان هو وقت الجماعة مطروحاً منه الإزاحة أعلاه."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার মসজিদের ঘোষণা অনুযায়ী সময়। আজানের চিপ হলো জামাতের সময় থেকে উপরের অফসেট বাদ দেওয়া।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Caminizin duyurduğu vakitler. Ezan etiketi, cemaat vaktinden yukarıdaki farkın çıkarılmasıdır."
          }
        }
      }
    }
  },
  "version": "1.0"
}
